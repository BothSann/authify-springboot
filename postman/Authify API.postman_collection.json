        {
          "name": "Refresh token (rotates tokens)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200 OK\", () => {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"New tokens returned and saved\", () => {\r",
                  "    const data = pm.response.json().data;\r",
                  "    pm.expect(data.accessToken).to.be.a('string').and.not.be.empty;\r",
                  "    pm.expect(data.refreshToken).to.be.a('string').and.not.be.empty;\r",
                  "    // Overwrite with new rotated tokens\r",
                  "    pm.environment.set(\"access_token\", data.accessToken);\r",
                  "    pm.environment.set(\"refresh_token\", data.refreshToken);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"refreshToken\": \"{{refresh_token}}\"\r\n}",
              "options": {
