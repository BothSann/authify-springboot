          "name": "Update my profile",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200 OK\", () => {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Name updated correctly\", () => {\r",
                  "    const data = pm.response.json().data;\r",
                  "    pm.expect(data.firstName).to.eql(\"Alicia\");\r",
                  "    pm.expect(data.lastName).to.eql(\"Johnson\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"updatedAt is newer than createdAt\", () => {\r",
                  "    const data = pm.response.json().data;\r",
                  "    pm.expect(new Date(data.updatedAt)).to.be.at.least(new Date(data.createdAt));\r",
