    {
      "name": "Auth",
      "item": [
        {
          "name": "Register new user",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 201 Created\", () => {\r",
                  "    pm.response.to.have.status(201);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response has success status field\", () => {\r",
                  "    const body = pm.response.json();\r",
                  "    pm.expect(body.status).to.eql(201);\r",
                  "    pm.expect(body.message).to.eql(\"Registration successful\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Access token and refresh token returned\", () => {\r",
                  "    const data = pm.response.json().data;\r",
                  "    pm.expect(data.accessToken).to.be.a('string').and.not.be.empty;\r",
                  "    pm.expect(data.refreshToken).to.be.a('string').and.not.be.empty;\r",
                  "    // Auto-save tokens for subsequent requests\r",
                  "    pm.environment.set(\"access_token\", data.accessToken);\r",
                  "    pm.environment.set(\"refresh_token\", data.refreshToken);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"email\": \"alice@example.com\",\r\n  \"password\": \"Password1@\",\r\n  \"firstName\": \"Alice\",\r\n  \"lastName\": \"Smith\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            }
          },
          "response": []
        },
